/* ===== CSS 变量 ===== */
page {
  --color-primary: #07C160;
  --color-primary-dark: #06AD56;
  --color-primary-light: #E8F8EF;
  --color-danger: #FA5151;
  --color-warning: #FFC300;
  --color-text: #1A1A1A;
  --color-text-secondary: #666666;
  --color-text-muted: #999999;
  --color-bg: #F6F6F6;
  --color-bg-card: #FFFFFF;
  --color-border: #E5E5E5;
  --color-divider: #F0F0F0;

  --radius-sm: 8rpx;
  --radius-md: 12rpx;
  --radius-lg: 16rpx;
  --radius-round: 50%;

  --shadow-sm: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
  --shadow-md: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);

  --font-xs: 22rpx;
  --font-sm: 24rpx;
  --font-md: 28rpx;
  --font-lg: 32rpx;
  --font-xl: 36rpx;
  --font-xxl: 44rpx;

  --spacing-xs: 8rpx;
  --spacing-sm: 12rpx;
  --spacing-md: 16rpx;
  --spacing-lg: 24rpx;
  --spacing-xl: 32rpx;

  box-sizing: border-box;
  font-size: var(--font-md);
  color: var(--color-text);
  background-color: var(--color-bg);
}

/* ===== Reset ===== */
view, text, image, input, textarea, button, navigator {
  box-sizing: border-box;
  margin: 0;
  padding: 0;
}

button {
  font-size: var(--font-md);
  line-height: 1;
}

button::after {
  border: none;
}

image {
  display: block;
}

/* ===== 安全区域适配 ===== */
.safe-area-bottom {
  padding-bottom: constant(safe-area-inset-bottom);
  padding-bottom: env(safe-area-inset-bottom);
}
