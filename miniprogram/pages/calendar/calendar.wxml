<view class="page-padded">
  <!-- 月份切换 -->
  <view class="flex-between px-lg pt-lg pb-md">
    <view class="btn btn-sm" bind:tap="prevMonth">◀</view>
    <view class="text-lg text-bold">{{currentYear}}年{{currentMonth}}月</view>
    <view class="btn btn-sm" bind:tap="nextMonth">▶</view>
  </view>

  <!-- 星期头 -->
  <view class="flex-between px-lg pb-sm">
    <view class="text-xs text-muted" style="width:14%" wx:for="{{['一','二','三','四','五','六','日']}}" wx:key="*this">{{item}}</view>
  </view>

  <!-- 日历格子 -->
  <view class="flex-wrap px-lg">
    <view
      wx:for="{{calendarDays}}"
      wx:key="index"
      class="cal-cell {{item.empty ? 'cal-cell--empty' : ''}}"
      data-date="{{item.date}}"
      bind:tap="onDayTap"
    >
      <text wx:if="{{!item.empty}}" class="cal-day">{{item.day}}</text>
    </view>
  </view>

  <!-- 选中日详情 -->
  <view wx:if="{{selectedDay}}" class="card">
    <view class="text-bold">{{selectedDay}}</view>
    <view wx:if="{{selectedDayInfo}}" class="text-sm text-muted mt-xs">
      {{selectedDayInfo.planName}} · {{selectedDayInfo.duration}}分钟
    </view>
    <view wx:else class="text-sm text-muted mt-xs">当日无训练记录</view>
  </view>

  <!-- 年度热力图 -->
  <view class="card">
    <view class="text-bold mb-md">年度训练热力图 ({{currentYear}})</view>
    <heatmap year="{{currentYear}}" data="{{heatmapData}}" />
    <view class="flex-align-center mt-sm">
      <text class="text-xs text-muted mr-sm">少</text>
      <view class="heat-legend-box level-0" />
      <view class="heat-legend-box level-1" />
      <view class="heat-legend-box level-2" />
      <view class="heat-legend-box level-3" />
      <view class="heat-legend-box level-4" />
      <text class="text-xs text-muted ml-sm">多</text>
    </view>
  </view>
</view>
