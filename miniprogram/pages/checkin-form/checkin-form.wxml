<view class="page-padded">
  <!-- 动作列表 -->
  <view wx:for="{{exercises}}" wx:key="exerciseId" class="card checkin-exercise">
    <view class="flex-between">
      <view class="flex-align-center">
        <view class="checkin-checkbox {{item.completed ? 'checkin-checkbox--done' : ''}}" data-index="{{index}}" bind:tap="toggleExercise">
          <text wx:if="{{item.completed}}">✓</text>
        </view>
        <view>
          <view class="text-bold">{{item.exerciseName}}</view>
          <view class="text-xs text-muted mt-xs">目标: {{item.sets}}组 × {{item.reps}}次</view>
        </view>
      </view>
      <view class="chip">{{item.muscleGroup}}</view>
    </view>

    <!-- 展开的打卡详情 -->
    <view wx:if="{{item.completed}}" class="checkin-detail mt-md">
      <view class="flex-between mb-sm">
        <text class="text-sm text-secondary">完成组数</text>
        <input class="checkin-input" type="number" value="{{item.setsCompleted || item.sets}}" data-index="{{index}}" bind:input="onSetsChange" />
      </view>

      <view class="flex-between mb-sm" wx:for="{{item.repsPerSet || []}}" wx:for-item="rep" wx:for-index="ri" wx:key="ri">
        <text class="text-sm text-secondary">第{{ri + 1}}组</text>
        <view class="flex-align-center">
          <input class="checkin-input checkin-input--small" type="number" value="{{rep}}" data-index="{{index}}" data-ri="{{ri}}" bind:input="onRepsChange" placeholder="次数" />
          <text class="text-xs text-muted ml-sm mr-sm">次</text>
          <input class="checkin-input checkin-input--small" type="digit" value="{{item.weightPerSet[ri] || 0}}" data-index="{{index}}" data-wi="{{ri}}" bind:input="onWeightChange" placeholder="重量" />
          <text class="text-xs text-muted ml-sm">kg</text>
        </view>
      </view>
    </view>

    <view wx:if="{{!item.completed}}" class="text-center text-xs text-muted mt-sm">点击左侧圆圈标记完成</view>
  </view>

  <!-- 心情 & 备注 -->
  <view class="card">
    <view class="text-bold mb-md">今日感受</view>
    <view class="flex-center">
      <view
        wx:for="{{[5,4,3,2,1]}}"
        wx:key="*this"
        class="mood-item {{mood === item ? 'mood-item--active' : ''}}"
        data-mood="{{item}}"
        bind:tap="onMoodSelect"
      >
        <text class="mood-emoji">{{item === 5 ? '😊' : item === 4 ? '🙂' : item === 3 ? '😐' : item === 2 ? '😕' : '😫'}}</text>
      </view>
    </view>

    <textarea class="checkin-textarea mt-md" value="{{notes}}" placeholder="训练备注..." bind:input="onNotesInput" maxlength="200" />
  </view>

  <!-- 照片 -->
  <view class="card">
    <view class="text-bold mb-md">进度照</view>
    <view class="flex-align-center">
      <view class="checkin-photo" wx:for="{{photos}}" wx:key="*this" data-index="{{index}}" bind:tap="deletePhoto">
        <image src="{{item}}" mode="aspectFill" />
        <view class="checkin-photo-delete">✕</view>
      </view>
      <view class="checkin-add-photo" bind:tap="choosePhoto" wx:if="{{photos.length < 3}}">
        <text class="text-muted" style="font-size: 48rpx;">+</text>
      </view>
    </view>
  </view>

  <!-- 提交按钮 -->
  <view class="px-md pb-lg">
    <view class="text-center text-sm text-muted mb-sm">完成 {{completedCount}}/{{totalExercises || exercises.length}} 个动作</view>
    <button class="btn btn-primary btn-block" loading="{{isSubmitting}}" disabled="{{isSubmitting}}" bind:tap="submit">
      完成打卡
    </button>
  </view>
</view>
