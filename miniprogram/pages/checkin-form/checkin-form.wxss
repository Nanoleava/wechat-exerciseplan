.checkin-exercise {
  transition: all 0.3s;
}

.checkin-checkbox {
  width: 48rpx;
  height: 48rpx;
  border: 3rpx solid var(--color-border);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: var(--spacing-md);
  font-size: var(--font-sm);
  color: #FFFFFF;
  flex-shrink: 0;
}

.checkin-checkbox--done {
  background: var(--color-primary);
  border-color: var(--color-primary);
}

.checkin-detail {
  padding: var(--spacing-md);
  background: var(--color-bg);
  border-radius: var(--radius-sm);
}

.checkin-input {
  width: 80rpx;
  height: 56rpx;
  background: var(--color-bg-card);
  border: 1rpx solid var(--color-border);
  border-radius: var(--radius-sm);
  text-align: center;
  font-size: var(--font-sm);
}

.checkin-input--small {
  width: 64rpx;
}

.checkin-textarea {
  width: 100%;
  height: 120rpx;
  font-size: var(--font-sm);
  padding: var(--spacing-sm);
  background: var(--color-bg);
  border-radius: var(--radius-sm);
}

.checkin-photo {
  position: relative;
  width: 140rpx;
  height: 140rpx;
  border-radius: var(--radius-sm);
  overflow: hidden;
  margin-right: var(--spacing-sm);
}

.checkin-photo image {
  width: 100%;
  height: 100%;
}

.checkin-photo-delete {
  position: absolute;
  top: 0;
  right: 0;
  width: 36rpx;
  height: 36rpx;
  background: rgba(0,0,0,0.5);
  color: #FFF;
  font-size: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 0 0 0 var(--radius-sm);
}

.checkin-add-photo {
  width: 140rpx;
  height: 140rpx;
  border: 2rpx dashed var(--color-border);
  border-radius: var(--radius-sm);
  display: flex;
  align-items: center;
  justify-content: center;
}

.mood-item {
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  margin: 0 var(--spacing-sm);
  border: 3rpx solid transparent;
}

.mood-item--active {
  border-color: var(--color-primary);
  background: var(--color-primary-light);
}

.mood-emoji {
  font-size: 40rpx;
}
